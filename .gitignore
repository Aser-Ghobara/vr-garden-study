# Unity project lives in /VRGarden inside this repository.
# Rules that target Unity root folders are prefixed with /VRGarden/.
# Base template: https://github.com/github/gitignore/blob/main/Unity.gitignore

/VRGarden/.utmp/
/VRGarden/[Ll]ibrary/
/VRGarden/[Tt]emp/
/VRGarden/[Oo]bj/
/VRGarden/[Bb]uild/
/VRGarden/[Bb]uilds/
/VRGarden/[Ll]ogs/
/VRGarden/[Uu]ser[Ss]ettings/
*.log

# By default Unity supports Blender asset imports; *.blend1 files are not needed.
*.blend1
*.blend1.meta

# Memory captures can be large and may contain sensitive data.
/VRGarden/[Mm]emoryCaptures/

# Recordings can get excessive in size.
/VRGarden/[Rr]ecordings/

# Uncomment if you want to ignore Asset Store tools plugin.
# /VRGarden/[Aa]ssets/AssetStoreTools*

# Autogenerated JetBrains Rider plugin.
/VRGarden/[Aa]ssets/Plugins/Editor/JetBrains*
# JetBrains Rider personal settings.
*.DotSettings.user

# Visual Studio cache directory.
.vs/

# Gradle cache directory.
.gradle/

# Autogenerated VS/MD/Consulo solution and project files.
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files.
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated crash report file.
sysinfo.txt

# Mono auto-generated files.
mono_crash.*

# Builds.
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file.
crashlytics-build.properties

# TestRunner generated files.
InitTestScene*.unity*

# Addressables default ignores, before user customizations.
/VRGarden/ServerData
/VRGarden/[Aa]ssets/StreamingAssets/aa*
/VRGarden/[Aa]ssets/AddressableAssetsData/link.xml*
/VRGarden/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /VRGarden/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/VRGarden/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files.
/VRGarden/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/VRGarden/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/VRGarden/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/VRGarden/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests.
/VRGarden/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
